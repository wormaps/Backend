{
  "version": "qg-policy.v1",
  "gates": {
    "geometry": {
      "criticalInvalidGeometryMax": 0,
      "criticalPolygonBudgetExceededMax": 0
    },
    "semantic": {
      "minObservedAppearanceRatio": {
        "warn": 0.05,
        "pass": 0.15
      }
    },
    "spatial": {
      "maxRoundTripErrorM": {
        "warn": 0.05,
        "fail": 0.25
      }
    },
    "delivery": {
      "requiredArtifactTypes": ["GLB", "SCENE_META", "SCENE_DETAIL"],
      "requireSemanticCoverage": "PARTIAL"
    },
    "state": {
      "requireSceneStateBinding": true,
      "requireEntityStateBinding": true
    }
  }
}
